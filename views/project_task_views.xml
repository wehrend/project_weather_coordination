<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_task_form2_weather_inherit" model="ir.ui.view">
            <field name="name">project.task.form.weather.inherit</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <div class="alert alert-danger" role="alert" invisible="not is_weather_blocked" style="margin-bottom: 15px;">
                        <strong>Weather Warning: </strong>This task was automatically blocked because bad weather is reported at the customer site.
                    </div>
                </xpath>
                <xpath expr="//field[@name='user_ids']" position="after">
                    <field name="weather_status"/>
                    <field name="is_weather_blocked" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
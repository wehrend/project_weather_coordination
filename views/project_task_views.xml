<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form2_weather_inherit" model="ir.ui.view">
        <name>project.task.form.weather.inherit</name>
        <model>project.task</model>
        <inherit_id ref="project.view_task_form2"/>
        <arch type="xml">
            <xpath expr="//sheet" position="inside">
                <div class="alert alert-danger" role="alert" attrs="{'invisible': [('is_weather_blocked', '=', False)]}" style="margin-bottom: 15px;">
                    <strong>Wetter warning:</strong> This task was automatically blocked because bad weather is reported at the customer site..
                </div>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="weather_status"/>
                <field name="is_weather_blocked" invisible="1"/>
            </xpath>
        </arch>
    </record>
</odoo>